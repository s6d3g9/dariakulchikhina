    "livekit-client": "^2.18.0",
    "nuxt": "^4.3.1",
    "pinia": "^3.0.4",
    "postgres": "^3.4.5",
    "tailwindcss": "^4.2.1",
    "werift": "^0.22.9",
    "zod": "^3.24.2"
