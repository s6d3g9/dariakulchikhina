{
  "name": "daria-kulchikhina",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --port 3000",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "messenger:web:dev": "pnpm -C messenger/web dev",
    "messenger:web:build": "NUXT_APP_BASE_URL=/messenger/ pnpm -C messenger/web build",
    "messenger:web:preview": "pnpm -C messenger/web preview",
    "messenger:core:dev": "pnpm -C messenger/core dev",
    "messenger:core:build": "pnpm -C messenger/core build",
    "messenger:core:start": "pnpm -C messenger/core start",
    "messenger:export:standalone": "bash scripts/export-messenger-standalone.sh",
    "comm:dev": "cd services/communications-service && node --watch --experimental-strip-types src/index.ts",
    "comm:start": "cd services/communications-service && node --experimental-strip-types src/index.ts",
    "comm:typecheck": "pnpm exec tsc -p services/communications-service/tsconfig.json --noEmit",
    "deploy:safe": "bash scripts/deploy-safe.sh",
    "deploy:safe:prod": "DEPLOY_HOST=daria-deploy DEPLOY_PATH=/opt/daria-nuxt APP_NAME=daria-nuxt HEALTHCHECK_URL=http://152.53.176.165:3000/admin bash scripts/deploy-safe.sh",
    "deploy:safe:prod:fast": "NO_PREFLIGHT=1 DEPLOY_HOST=daria-deploy DEPLOY_PATH=/opt/daria-nuxt APP_NAME=daria-nuxt HEALTHCHECK_URL=http://152.53.176.165:3000/admin bash scripts/deploy-safe.sh",
    "deploy:safe:prod:dry-run": "DRY_RUN=1 DEPLOY_HOST=daria-deploy DEPLOY_PATH=/opt/daria-nuxt APP_NAME=daria-nuxt HEALTHCHECK_URL=http://152.53.176.165:3000/admin bash scripts/deploy-safe.sh",
    "deploy:safe:prod:preflight": "PREFLIGHT_ONLY=1 DEPLOY_HOST=daria-deploy DEPLOY_PATH=/opt/daria-nuxt APP_NAME=daria-nuxt HEALTHCHECK_URL=http://152.53.176.165:3000/admin bash scripts/deploy-safe.sh",
    "deploy:metrics": "tail -n 20 logs/deploy-metrics.log",
    "deploy:metrics:follow": "tail -f logs/deploy-metrics.log",
    "snapshot:list": "ls -1t builds/pre-deploy/*.bundle 2>/dev/null || echo 'no snapshots yet'",
    "snapshot:restore:last": "bash scripts/restore-last-snapshot.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "migrate:json": "node --experimental-vm-modules scripts/migrate-json-to-pg.mjs",
    "migrate:designer-catalog-keys": "node scripts/migrate-designer-catalog-keys.mjs",
    "docs:v5:verify": "node scripts/verify-architecture-docs.mjs",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File scripts/install-git-hooks.ps1"
  },
  "dependencies": {
    "@nuxt/ui": "^3.1.0",
    "@pinia/nuxt": "^0.11.3",
