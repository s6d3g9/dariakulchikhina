{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "~/shared/*": ["../../shared/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "__tests__/**/*.ts"]
}
