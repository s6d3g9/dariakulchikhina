# Session-specific deploy config
DEPLOY_HOST=daria-deploy
DEPLOY_BRANCH=refactor/architecture-v5
DEPLOY_PATH=/opt/daria-nuxt
APP_NAME=daria-nuxt
APP_PM2_USER=admin2

HEALTHCHECK_URL=http://152.53.176.165:3000/admin
REMOTE_HEALTHCHECK_URL=http://127.0.0.1:3000/admin
HEALTHCHECK_ATTEMPTS=6
HEALTHCHECK_DELAY=5

DEPLOY_MESSENGER=1
MESSENGER_ECOSYSTEM_PATH=messenger/ecosystem.config.cjs
MESSENGER_PM2_CORE_NAME=daria-messenger-core
MESSENGER_PM2_WEB_NAME=daria-messenger-web
MESSENGER_PM2_USER=admin2
MESSENGER_PUBLIC_HEALTHCHECK_URL=https://dariakulchikhina.com/messenger/login
MESSENGER_REMOTE_HEALTHCHECK_URL=http://127.0.0.1:3300/messenger/login

PREFLIGHT=1
PREFLIGHT_ONLY=0
NO_PREFLIGHT=0
DRY_RUN=0

AUTO_GIT_SAVE=1
LOCAL_SNAPSHOT_BEFORE_DEPLOY=1
LOCAL_SNAPSHOT_KEEP=10
TRACK_DEPLOY_BRANCHES=1
DEPLOY_LATEST_BRANCH=deploy/latest
DEPLOY_PREVIOUS_BRANCH=deploy/previous
